    COMPLETE = 'COMPLETE'
    SDP_ERROR = 'SDP_ERROR'

class MediaType(Enum):
    AUDIO = 'audio'
    VIDEO = 'video'

class MediaIPType(Enum):
    IPV4 = 'IPV4'
    IPV6 = 'IPV6'

class MediaDirection(Enum):
    SENDRECV = 'sendrecv'
    SENDONLY = 'sendonly'
    RECVONLY = 'recvonly'
    INACTIVE = 'inactive'

    
class Transport(Enum):
    TCP = 'TCP'
    UDP = 'UDP'

class Direction(Enum):
    SEND = 'send'
    RECV = 'recv'
    
class TestCaseResult(Enum):
    NONE = 'NONE'    
    PASS = 'PASS'
    FAIL = 'FAIL'
    
class TestCaseStatus(Enum):
    PENDING = 'PENDING'
    INPROGRESS = 'INPROGRESS'
