from sipconstants import SipHeaders, CRLF, TestCaseResult, SDPState
from sipmessage import SipMessage, getHeaderName
from uasession import UASession
from util import getMyHostIP
from sdp import SDP, SDPMLine
from testreport import TestReport
import json
import glob
from collections import OrderedDict

def parseHeaders(sig_msg):        
    sig_msg = sig_msg.split(CRLF)
    sipMessage = SipMessage()
    if sig_msg[0].startswith('SIP/2.0'):
        sipMessage.setResponseLine(sig_msg[0])
        #sipMessage.setMessageType(False)
    else:
        sipMessage.setRequestLine(sig_msg[0]) 
        #sipMessage.setMessageType(True)
    headers = sig_msg[1:]    
    for hdrs in headers:                     
        hdr = hdrs.split(':',1)        
        hdr_name = hdr[0]
        hdr_name = getHeaderName(hdr_name)        
        hdr_value = hdr[1].strip()     
        sipMessage.addHeader(hdr_name,hdr_value)
    return sipMessage

def parseContent(content):
    cont_len = len(content)
    content = content.split(CRLF)
    sdp = SDP()
    sdp.setContentLength(cont_len)
    hasMlineParsed = False       
    for hdr in content:
        if hdr.startswith('v='):
            sdp.setVline(hdr)
        elif hdr.startswith('o='):
            sdp.setOline(hdr)
        elif hdr.startswith('s='):
            sdp.setSline(hdr)
        elif hdr.startswith('t='):
            sdp.setTline(hdr)
        elif hdr.startswith('c='):
            if hasMlineParsed:
                mline = sdp.getLastMline()
                mline.setCline(hdr)
            else:
                sdp.setCline(hdr)
        elif hdr.startswith('a='):
            if hasMlineParsed:
                mline = sdp.getLastMline()
                mline.appendAline(hdr)
            else:
                sdp.appendALine(hdr)
        elif hdr.startswith('m='):
            hasMlineParsed = True
            mline = SDPMLine()            
            mline.setMline(hdr)
            sdp.appendMline(mline)
            
    return sdp            
      
    
def parseJson():
    data = None
    filepath = glob.glob('/root/useragent/json/*.json')[0]
    with open(filepath) as file:
        data = json.load(file)
    usr_input = None
    for key in data:
        usr_input = data.get(key)
    return usr_input

def parseCallFlow(data):
    key_len = len(data)
    msg_len = key_len - 12
    map = OrderedDict()
    for i in range(msg_len):
            map[i] = [data.get(str(i)).get("event"),data.get(str(i)) ]                        
    return map

def parseInputAndModifyMessage(map, message:SipMessage):    
    for key, values in map.items():
        if key == "INS_HDR":
            for value in values:
                hdr_name = value.split(':')[0]
                hdr_name = getHeaderName(hdr_name)
                hdr_value = value.split(':',1)[1]
                message.removeHeader(hdr_name)
                message.addHeader(hdr_name, hdr_value)
        elif key == "REM_HDR":
            for value in values:
                hdr_name = value.split(':')[0]
                hdr_name = getHeaderName(hdr_name)
                message.removeHeader(hdr_name)
        elif key == "REP_HDR":
            for value in values:
                hdr_name = value.split(':')[0]
                hdr_name = getHeaderName(hdr_name)
                hdr_value = value.split(':')[1]
                message.replaceHeader(hdr_name, hdr_value)
        elif key == "REP_REQURI":
            if values:
                message.replaceRequestURI(values)


def parseInputAndBuildContent(uaSession:UASession,sdpsessattrs,sdpmlines,mediadirection,audiocodecs,hascontentchanged,issrtp):      
    content = ""
    sdp_version = uaSession.getSDPVersion()
    if mediadirection or sdpmlines or audiocodecs or sdpsessattrs or hascontentchanged:
        sdp_version += 1
        uaSession.setSDPVersion(sdp_version)
                   
    content = f'v=0' + CRLF
    content += f'o=ua 1 {sdp_version} IN IP4 ua.automation.com' + CRLF
    content += f's= '+ CRLF
    content += f'c=IN IP4 {getMyHostIP()}' + CRLF
    content += f't=0 0' + CRLF
    for sesattr in sdpsessattrs:
        content += sesattr + CRLF
    if sdpmlines and (sdpmlines[0] == -1 or sdpmlines[0] == str(-1)):
        return content # will retun SDP only with session attributes but no m= line
    if not mediadirection:
        mediadirection = "sendrecv"
        if uaSession.getSDPState() == SDPState.SDP_RCVD.value:
            remoteSDP = uaSession.getRemoteSDP()
            remAudMediaDir = (remoteSDP.getMlines())[0].getMediaDirection()
            if remAudMediaDir == "sendonly":
                mediadirection= "recvonly"
            elif remAudMediaDir == "recvonly":
                mediadirection = "sendonly"
            elif remAudMediaDir == "inactive":
                mediadirection = "inactive"
    audiocodecs = audiocodecs if audiocodecs else [0]     
    content += f'm=audio 60000 RTP/SAVP' if issrtp else f'm=audio 60000 RTP/AVP'

    for codec in audiocodecs:
        content += f' {int(codec)}'
    # content +=  f' 101' + CRLF
    content += CRLF
    for codec in audiocodecs:
        if int(codec) == 0:
            content += f'a=rtpmap:0 PCMU/8000' + CRLF
        elif int(codec) == 4:
            content += f'a=rtpmap:4 G723/8000' + CRLF
        elif int(codec) == 8:
            content += f'a=rtpmap:8 PCMA/8000' + CRLF
        elif int(codec) == 9:
            content += f'a=rtpmap:9 G722/8000' + CRLF
        elif int(codec) == 18:
            content += f'a=rtpmap:18 G729/8000' + CRLF
    # content += f'a=rtpmap:101 telephone-event/8000' + CRLF
    # content += f'a=fmtp:101 0-15' + CRLF
    content += f'a={mediadirection}' + CRLF
    if issrtp:
        tag = 1
        crypto_suite = 'AES_CM_128_HMAC_SHA1_80'
        mastersalt_key = 'AQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEB'
        lifetime = '2^32'
        mki = 1
        mki_len = 32
        key_param = f'inline:{mastersalt_key}' #{lifetime}|{mki}:{mki_len}'
        content += f'a=crypto:{tag} {crypto_suite} {key_param}' + CRLF
    # if sdpmlines
    for mlines in sdpmlines:
        lst = mlines.split(',')
        for l in lst:
            content += l + CRLF
            
    return content


def buildMessage(sipMessage:SipMessage, content:str) -> str:
    raw_message = ""
    if sipMessage.getRequestLine() != None:
        # Build Request                  
        raw_message = sipMessage.getRequestLine() + CRLF          
    else:
        raw_message = sipMessage.getResponseLine() + CRLF
    headers = sipMessage.getAllHeaders()    
    for header in headers:
        hdr_vals = headers[header]
        for hdr_val in hdr_vals:            
            raw_message += f'{header}: {hdr_val}' + CRLF
    raw_message += CRLF     
    raw_message += content           
    
    return raw_message 


def parseInputAndVerifyMessage(map, message:SipMessage):
    test_report = TestReport.getInstance()
    if test_report.getSignalingResult() == TestCaseResult.FAIL.value : return
    res = True
    for key, values in map.items():
        if key == "EXP_HDR":
            for hdr in values:
                res = message.isHeaderPresent(hdr)
                if not res:
                    test_report.setSignalingReport(TestCaseResult.FAIL.value, f'Header {hdr} not Present')
                    break
                else:
                    test_report.setSignalingReport(TestCaseResult.PASS.value)
        if key == "INV_EXP_HDR":
            for hdr in values:
                res = message.isHeaderPresent(hdr)
                if res:
                    test_report.setSignalingReport(TestCaseResult.FAIL.value, f'Header {hdr} not Present')
                    break
                else:
                    test_report.setSignalingReport(TestCaseResult.PASS.value)              
        elif key == "EXP_HDRVALUE":
            for value in values:
                lst = value.split(':')
                hdr = lst[0]
                exp_val = lst[1]
                hdr_value = message.getHeader(hdr)[0]
                res = False if hdr_value.find(exp_val) == -1 else True
                if res:
                    test_report.setSignalingReport(TestCaseResult.PASS.value)
                else:
                    test_report.setSignalingReport(TestCaseResult.FAIL.value, f'Expected {hdr_value} not Present in {hdr} Header')
                    break
        elif key == "INV_EXP_HDRVALUE":
            for value in values:
                lst = value.split('=')
                hdr = lst[0]
                exp_val = lst[1]
                hdr_value = message.getHeader(hdr)[0]
                res = False if hdr_value.find(exp_val) == -1 else True
                if not res:
                    test_report.setSignalingReport(TestCaseResult.PASS.value)
                else:
                    test_report.setSignalingReport(TestCaseResult.FAIL.value, f'Unexpected {hdr_value} Present in {hdr} Header')
                    break
        elif key == "EXP_REQURI":
            if values:
                exp_requri = values
                act_requri = message.getRequestURL()
                if exp_requri != act_requri:
                    test_report.setSignalingReport(TestCaseResult.FAIL.value, "expected Req URI didn't match")
                    break
                else:
                    test_report.setSignalingReport(TestCaseResult.PASS.value)                
        elif key == "INV_EXP_REQURI":
            if values:
                exp_requri = values
                act_requri = message.getRequestURL()
                if exp_requri == act_requri:
                    test_report.setSignalingReport(TestCaseResult.FAIL.value, "expected Req URI didn't match")
                    break
                else:
                    test_report.setSignalingReport(TestCaseResult.PASS.value)
        
                
                
                