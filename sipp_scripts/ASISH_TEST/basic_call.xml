<scenario name="Basic Sipstone UAC">
<!-- In client mode (sipp placing calls), the Call-ID MUST be         -->
<!-- generated by sipp. To do so, use [call_id] keyword.                -->

<send retrans="500" crlf="true">
<![CDATA[
  INVITE sip:[field1]@[field2] SIP/2.0
    From: sip:[field0]@[field2];tag=[call_number]
      To: sip:[field1]@[field2]
        Call-ID: [call_id]
          CSeq: 1 INVITE
            Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
              Content-Length: [len]
                Max-Forwards: 70
                  Session-Expires: 1200;refresher=uas
                    Min-SE: 1200
                      Contact:"VENKI" <sip:[field0]@[local_ip]:[local_port];transport=[transport]>
                        Allow: INVITE,CANCEL,BYE,ACK,INFO,REFER,UPDATE
                          Supported: replaces,100rel
                            Require: 100rel
                              User-Agent: Avaya CM/R016x.00.0.443.0
                                Content-Type: application/sdp

  v=0
    o=user1 53655765 50 IN IP[local_ip_type] [local_ip]
      s=-
        c=IN IP[media_ip_type] [local_ip]
          t=0 0
            m=audio 5090 RTP/AVP 0 8
              a=rtpmap:0 PCMU/8000/1
                a=rtpmap:8 PCMA/8000/1

]]>
</send>

<recv response="100">
</recv>

<recv response="181" optional="true">
</recv>

<recv response="183" optional="true">
</recv>


<recv response="180" optional="true">
</recv>

<recv response="181" optional="true">
</recv>


<recv response="183" optional="true">
</recv>


<recv response="200" rrs="true">
  <action>
  	  <ereg regexp="Contact:.*" search_in="hdr" assign_to="1"/>
  	    </action>
  	    </recv>

<!-- Packet lost can be simulated in any send/recv message by         -->
<!-- by adding the 'lost = "10"'. Value can be [1-100] percent.       -->
<send>
<![CDATA[

  ACK sip:[field1]@avaya.com SIP/2.0
    From: sip:[field0]@[field2];tag=[call_number]
      To: sip:[field1]@[field2][peer_tag_param]
        Call-ID: [call_id]
          CSeq: 1 ACK
            Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
              [routes]
                User-Agent: Avaya CM/R016x.00.0.338.0
                  Content-Length: 0
                    Max-Forwards: 70

]]>
</send>

