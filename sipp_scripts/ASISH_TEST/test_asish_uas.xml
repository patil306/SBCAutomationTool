<!-- Assumes you have already registered the UAS endpoint -->
<scenario name="Basic UAS responder">
  <recv request="INVITE" rrs="true" crlf="true">
        <action>
                    <ereg regexp="[0-9]{1,6}" search_in="hdr" header="To:" check_it="true" assign_to="6" />
                                      <ereg regexp=";tag=.*" search_in="hdr" header="From:" check_it="true" assign_to="5" />
                                                            </action>
                                                                                    </recv>
                                                                                                              <!-- The '[last_*]' keyword is replaced automatically by the          --> specified header if it was present in the last message received  <!-- (except if it was a retransmission). If the header was not       --><!-- present or if no message has been received, the '[last_*]'       --><!-- keyword is discarded, and all bytes until the end of the line    --><!-- are also discarded.                                         

