<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<scenario name="Basic UAS responder">

<!-- By adding rrs="true" (Record Route Sets), the route sets         -->
<!-- are saved and used for following messages sent. Useful to test   -->
<!-- against stateful SIP proxies/B2BUAs.                             -->  
<!-- The '[last_*]' keyword is replaced automatically by the          -->
<!-- specified header if it was present in the last message received  -->
<!-- (except if it was a retransmission). If the header was not       -->
<!-- present or if no message has been received, the '[last_*]'       -->
<!-- keyword is discarded, and all bytes until the end of the line    -->
<!-- are also discarded.                                              -->
<!--                                                                  -->
<!-- If the specified header was present several times in the         -->
<!-- message, all occurences are concatenated (CRLF seperated)        -->
<!-- to be used in place of the '[last_*]' keyword.                   -->



<recv request="INVITE" crlf="true">
<action>
</action>
</recv>
    
<send>
    <![CDATA[
        SIP/2.0 100 Trying
        [last_Via:]
        [last_From:]
        [last_To:]
        [last_Call-ID:]
        [last_CSeq:]
        [last_Record-Route:]
        Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport]>
        Content-Length: 0
    ]]>
</send>

<send>
    <![CDATA[
        SIP/2.0 180 Ringing
        [last_Via:]
        [last_From:]
        [last_To:];tag=[call_number]
        [last_Call-ID:]
        [last_CSeq:]
        [last_Record-Route:]
        Contact: "Automation"<sip:[field0]@[local_ip]:[local_port];transport=[transport]>
        Content-Length: 0
    ]]>
</send>
    
<send retrans="500">
    <![CDATA[
        SIP/2.0 200 OK
        [last_Via:]
        [last_From:]
        [last_To:];tag=[call_number]
        [last_Call-ID:]
        [last_CSeq:]
        [last_Record-Route:]
        Contact: "Automation"<sip:[field0]@[local_ip]:[local_port];transport=[transport]>
        Content-Type: application/sdp
        Content-Length: [len]

        v=0
        o=user1 53655765 2353687637 IN IP[local_ip_type] [local_ip]
        s=-
        c=IN IP[media_ip_type] [media_ip]
        t=0 0
        m=audio [media_port] RTP/AVP 0 8 101
        a=rtpmap:0 PCMU/8000
        a=rtpmap:8 PCMA/8000/1
        a=rtpmap:101 telephone-event/8000

    ]]>
  </send>

<recv request="ACK" rtd="true" crlf="true">
<action>
	<ereg regexp="sip.*[^>]" search_in="hdr" header="Contact:" assign_to="1"/>
	<ereg regexp=".*" search_in="hdr" header="From: " assign_to="UserAFrom"/>
	<ereg regexp=".*" search_in="hdr" header="To: " assign_to="UserATo"/>
</action>
</recv>

<!-- Call C -->

<send retrans="500">
    <![CDATA[
        INVITE sip:8005@sippcs.com SIP/2.0
        Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
        From: <sip:[field0]@[field1]>;tag=3
        To: <sip:8005@sippcs.com>
        Call-ID: 123///[call_id]
        CSeq: [cseq] INVITE
        Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport]>
        Supported: replaces
        Max-Forwards: 70
        Subject: SBC Automation
        User-to-User: 00FA080001001056965CFB;encoding=hex
        Content-Type: application/sdp
        Content-Length: [len]

        v=0
        o=user1 53655765 2353687637 IN IP[local_ip_type] [local_ip]
        s=-
        c=IN IP[media_ip_type] [media_ip]
        t=0 0
        m=audio [media_port] RTP/AVP 0 8 101
        a=rtpmap:0 PCMU/8000
        a=rtpmap:8 PCMA/8000/1
        a=rtpmap:101 telephone-event/8000
    ]]>
</send>

<recv response="100" optional="true">
</recv>

<recv response="180" optional="true">
</recv>


<!-- are saved and used for following messages sent. Useful to test   -->
<!-- against stateful SIP proxies/B2BUAs.                             -->

<recv response="200" rrs="true">
  <action>
  	<ereg regexp="sip.*[^>]" search_in="hdr" header="Contact:" assign_to="UserBContact"/>
        <ereg regexp=".*" search_in="hdr" header="From: " assign_to="UserBFrom"/>
        <ereg regexp=".*" search_in="hdr" header="To: " assign_to="UserBTo"/>
        <ereg regexp="tag=([[:alnum:]\-]*)" search_in="hdr" header="To:" check_it="true" assign_to="ToTag1,ToTag2" />
        <ereg regexp="tag=([[:alnum:]\-]*)" search_in="hdr" header="From:" check_it="true" assign_to="FromTag1,FromTag2" />
  </action>
</recv>

<Reference variables="ToTag1" />
<Reference variables="FromTag1" />
<Reference variables="UserBFrom" />

<send>
    <![CDATA[
        ACK [$UserBContact] SIP/2.0
        Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
        From: sip:[field0]@[field1];tag=3
        To: [$UserBTo]
        Call-ID: 123///[call_id]
        CSeq: [cseq] ACK
        Contact: <sip:[field0]@[local_ip]:[local_port];transport=TCP>
        Max-Forwards: 70
        [routes]
        Subject: Automation
        Content-Length: 0
    ]]>
</send>

<send>
<![CDATA[
REFER [$1] SIP/2.0
Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
From: [$UserATo]
To: [$UserAFrom]
Call-ID: [call_id]
CSeq: 1 REFER
Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport]>
Refer-To: <sip:[field4]@[field5]?Replaces=123///[call_id]%3Bfrom-tag%3D[$FromTag2]%3Bto-tag%3D[$ToTag2]>
Referred-By: <sip:[field0]@[field1]>
[routes]
Max-Forwards: 70
Subject: Automation
Content-Length: [len]


]]>
</send>

<recv response="202"  optional="true">
</recv>

<recv request="BYE">
<action>
</action>
</recv>

<send>
    <![CDATA[
        SIP/2.0 200 OK
        [last_Via:]
        [last_From:]
        [last_To:]
        [last_Call-ID:]
        [last_CSeq:]
        Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport]>
        Content-Length: 0
    ]]>
</send>
<recv request="NOTIFY">
</recv>

<send>
<![CDATA[
SIP/2.0 200 OK
[last_Via:]
[last_From:]
[last_To:]
[last_Call-ID:]
Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport]>
[last_CSeq:]
Content-Length: 0
]]>
</send>
