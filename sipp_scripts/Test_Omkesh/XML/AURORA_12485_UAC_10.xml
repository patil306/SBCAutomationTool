<scenario name="Basic Sipstone UAC">
  <!-- In client mode (sipp placing calls), the Call-ID MUST be         -->
  <!-- generated by sipp. To do so, use [call_id] keyword.                -->
  <send retrans="500">
  <![CDATA[
  INVITE sip:[field0]@[remote_ip]:[remote_port] SIP/2.0
  Via: SIP/2.0/[transport] [local_ip]:[local_port];alias;branch=[branch];rport
  From: sipp <sip:sipp@[local_ip]:[local_port]>;tag=[pid]SIPpTag00[call_number]
  To: sut <sip:[field0]@[remote_ip]:[remote_port]>
  Call-ID: [call_id]
  CSeq: 1 INVITE
  Record-Route: <sip:[local_ip]:[local_port];transport=tcp;lr>
  Contact: <sip:sipp@[remote_ip]:[local_port];transport=[transport]>
  Supported: 100rel
  Max-Forwards: 70
  Subject: Performance Test
  Content-Type: application/sdp
  Content-Length: [len]

  v=0
  o=user1 1 17 IN IP[local_ip_type] [local_ip]
  s=-
  c=IN IP[media_ip_type] [media_ip]
  b=AS:64
  t=0 0
  m=audio [media_port] RTP/AVP 0 96
  a=rtpmap:0 PCMU/8000
  a=rtpmap:96 telephone-event/8000
  a=sendrecv
  m=video 0 RTP/AVP 0 96
  a=rtpmap:0 PCMU/8000
  a=rtpmap:96 telephone-event/8000
  a=sendrecv
  ]]>
  </send>
<!--
a=tcap:1 RTP/SAVP
a=acap:1 crypto:1 AES_CM_128_HMAC_SHA1_80 inline:vJN9Am+HTpaTro2mQwJelyHw0YkCVzYZkWmYqfiz UNENCRYPTED_SRTCP
a=pcfg:1 t=1 a=1
m=audio [media_port+2] RTP/AVP 0 9 120
c=IN IP6 2001:db8::d171
a=rtpmap:0 PCMU/8000/1
a=rtpmap:9 G722/8000/1
a=rtpmap:120 telephone-event/8000/1
a=mid:59
a=tcap:1 RTP/SAVP
a=acap:1 crypto:1 AES_CM_128_HMAC_SHA1_80 inline:vJN9Am+HTpaTro2mQwJelyHw0YkCVzYZkWmYqfiz UNENCRYPTED_SRTCP
a=pcfg:1 t=1 a=1
-->                           
  <recv response="100"
        optional="true">
  </recv>

  <recv response="180" optional="true">
  </recv>


  <!-- By adding rrs="true" (Record Route Sets), the route sets         -->
  <!-- are saved and used for following messages sent. Useful to test   -->
  <!-- against stateful SIP proxies/B2BUAs.                             -->
  <recv response="200" rrs="true" rtd="true">
  </recv>

  <!-- Packet lost can be simulated in any send/recv message by         -->
  <!-- by adding the 'lost = "10"'. Value can be [1-100] percent.       -->
  <send>
  <![CDATA[
  ACK sip:[field0]@[remote_ip]:[remote_port] SIP/2.0
  Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
  From: sipp <sip:sipp@[local_ip]:[local_port]>;tag=[pid]SIPpTag00[call_number]
  To: sut <sip:[field0]@[remote_ip]:[remote_port]>[peer_tag_param]
  Call-ID: [call_id]
  CSeq: 1 ACK
  Contact: <sip:sipp@[local_ip]:[local_port];transport=[transport]>
  Max-Forwards: 70
  Subject: Performance Test
  Content-Length: 0
  ]]>
  </send>
<!-- ADITYA___FROM_HERE:this is done now, just to run basic capneg will remove this once thsings settled-->
<recv request="INVITE" rrs="true" crlf="true">
</recv>

<send retrans="1500">
<![CDATA[
SIP/2.0 200 OK
[last_Via:]
[last_From:]
[last_To:]
[last_Call-ID:]
[last_CSeq:]
