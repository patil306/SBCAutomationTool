<recv request="ACK" rtd="true" crlf="true">
<action>
  <ereg regexp="tag=.*"
          search_in="hdr"
                  header="From:"
                          check_it="true"
                                  assign_to="1"/>

   <ereg regexp="tag=.*"
            search_in="hdr"
                     header="To:"
                              check_it="true"
                                       assign_to="2"/>

   <ereg regexp=".*"
             search_in="hdr"
                       header="Call-ID:"
                                 check_it="true"
                                           assign_to="3"/>
                                            </action>
</recv>
<recv request="INVITE" rrs="true" crlf="true">
</recv>


  <send retrans="1500">
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:];tag=[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Record-Route:[$5]
      Allow: INVITE,REFER,NOTIFY,UPDATE,SUBSCRIBE,INFO
      Contact: "PRAMOD" <sip:[$6]@[local_ip]:[local_port];transport=tcp>
      Resource-Priority: medpro
      P-Asserted-Identity: "AVAYALABS" <sip:[$6]@nortel.com>
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=user1 987650 1 IN IP[local_ip_type] [local_ip]
      s=-
      c=IN IP6 [media_ip]
      t=0 0
      m=audio 8000 RTP/AVP 0 120
      a=rtpmap:0 PCMU/8000
      a=rtpmap:120 telephone-event/8000
      a=sendrecv
      m=video 8002 RTP/AVP 0 96
      a=rtpmap:0 PCMU/8000
      a=rtpmap:96 telephone-event/8000
      a=sendrecv
    ]]>
  </send>

  <recv request="ACK" rtd="true" crlf="true">
  </recv>

<pause milliseconds="8000"/>
  <!-- The 'crlf' option inserts a blank line in the statistics report. -->
  <send retrans="500">
    <![CDATA[
      BYE sip:[field0]@[remote_ip]:[remote_port] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
      From: [field1] <sip:[field1]@[field3]>;[$2]
      To: [field0] <sip:[field0]@[field2]>;[$1]
      Record-Route:[$5]
      Call-ID:[$3]
      CSeq: 4 BYE
      Contact: <sip:sipp@[local_ip]:[local_port];transport=[transport]>
      [routes]
      Max-Forwards: 70
      Subject: Performance Test
      Content-Length: [len]
      ]]>
      </send>

  <recv response="200" crlf="true">
    </recv>

  <!--eKeep the call open for a while in case the 200 is lost to be     -->
  <!-- able to retransmit it if we receive the BYE again.               -->

  <!-- definition of the response time repartition table (unit is ms)   -->
  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>

  <!-- definition of the call length repartition table (unit is ms)     -->
  <CallLengthRepartition value="10, 50, 100, 500, 1000, 5000, 10000"/>

</scenario>
