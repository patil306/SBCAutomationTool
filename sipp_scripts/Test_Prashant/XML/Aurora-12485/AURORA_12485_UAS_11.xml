<!-- Assumes you have already registered the UAS endpoint -->

<!--
	<ereg regexp=".*" search_in="hdr" header="To:" check_it="true" assign_to="1"/>
	<ereg regexp=".*" search_in="hdr" header="From:" check_it="true" assign_to="2"/>
	<ereg regexp=".*" search_in="hdr" header="To:" check_it="true" assign_to="1"/>
	<ereg regexp=".*" search_in="hdr" header="From:" check_it="true" assign_to="2"/>
-->
<scenario name="Basic UAS responder">

<recv request="INVITE" rrs="true" crlf="true">
	<action>
	<ereg regexp=".*" search_in="hdr" header="Record-Route:" check_it="true" assign_to="5"/>
<!--	<ereg regexp=".*" search_in="hdr" header="Via:" check_it="true" assign_to="7"/>
     	-->
	<ereg regexp="[0-9]{1,5}" search_in="hdr" header="To:" check_it="true" assign_to="6"/>
	</action>
</recv>
  
<!-- The '[last_*]' keyword is replaced automatically by the          -->
<!-- specified header if it was present in the last message received  -->
<!-- (except if it was a retransmission). If the header was not       -->
<!-- present or if no message has been received, the '[last_*]'       -->
<!-- keyword is discarded, and all bytes until the end of the line    -->
<!-- are also discarded.                                              -->
<!--                                                                  -->
<!-- If the specified header was present several times in the         -->
<!-- message, all occurences are concatenated (CRLF seperated)        -->
<!-- to be used in place of the '[last_*]' keyword.                   -->

<!-- Record-Route: <sip:192.168.10.134:5060;transport=TCP;lr> -->

<send>
<![CDATA[
SIP/2.0 100 Trying
[last_Via:]
[last_From:]
[last_To:];tag=[call_number]
[last_Call-ID:]
Record-Route:[$5]
[last_CSeq:]
Content-Length: 0
]]>
</send>

<send>
<![CDATA[
SIP/2.0 180 Ringing
[last_Via:]
[last_From:]
[last_To:];tag=[call_number]
[last_Call-ID:]
Record-Route:[$5]
[last_CSeq:]
Contact: <sip:[$6]@[local_ip]:[local_port];transport=tcp>;isfocus
Content-Length: [len]
]]>
</send>



<send retrans="1500">
<![CDATA[
SIP/2.0 200 OK
[last_Via:]
[last_From:]
[last_To:];tag=[call_number]
[last_Call-ID:]
[last_CSeq:]
Record-Route:[$5]
Allow: INVITE,REFER,NOTIFY,UPDATE,SUBSCRIBE,INFO
Allow-Events: conference
Contact: <sip:[$6]@[local_ip]:[local_port];transport=tcp>
[routes]
Content-Type: application/sdp
Content-Length: [len]

v=0
o=user1 987650 1 IN IP[local_ip_type] [local_ip]
s=-
c=IN IP[local_ip_type] [media_ip]
b=AS:1000
t=0 0
m=audio 8000 RTP/AVP 0 96
a=rtpmap:0 PCMU/8000
a=rtpmap:96 telephone-event/8000
a=sendrecv
m=video 8002 RTP/AVP 0 96
a=rtpmap:0 PCMU/8000
a=rtpmap:96 telephone-event/8000
a=sendrecv
]]>
</send>
