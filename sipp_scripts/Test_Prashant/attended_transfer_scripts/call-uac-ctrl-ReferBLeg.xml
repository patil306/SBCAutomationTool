<scenario name="Basic UAS responder">
  <!-- By adding rrs="true" (Record Route Sets), the route sets         -->
  <!-- are saved and used for following messages sent. Useful to test   -->
  <!-- against stateful SIP proxies/B2BUAs.                             -->

  <!-- The '[last_*]' keyword is replaced automatically by the          -->
  <!-- are also discarded.                                              -->
  <!--                                                                  -->
  <!-- If the specified header was present several times in the         -->
  <!-- message, all occurences are concatenated (CRLF seperated)        -->
  <!-- to be used in place of the '[last_*]' keyword.                   -->

 <recvCmd>
 </recvCmd>

  <send>
    <![CDATA[

      INVITE sip:[field1]@[remote_ip]:[remote_port];transport=[transport] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
      From: [field0] <sip:[field0]@[local_ip]:[local_port]>;tag=[pid]SIPpTag00[call_number]
      To: sut <sip:[field1]@[remote_ip]:[remote_port]>[peer_tag_param]
      Call-ID: [call_id]
      CSeq: [cseq] INVITE
      P-Asserted-Identity: <sip:[field0]@[local_ip];user=phone>
      History-Info: <sip:16139675279@207.245.2.12;user=phone>;index=1.1
      Record-Route: <sip:4ac343a6@10.135.88.199:5062;lr>                                                               
      Record-Route: <sip:4ac343a6@10.96.16.158;transport=tcp;lr>                                                       
      Record-Route: <sip:10.96.16.157:15060;transport=tcp;ibmsid=local.1523175997892_1508386_1985712;lr>               
      Record-Route: <sip:4ac343a6@10.96.16.158:5068;transport=tcp;lr>                                                  
      Record-Route: <sip:10.96.16.150:5068;transport=tcp;lr>
      Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport]>
      P-Location: SM;orginator="werwerewr"
      Max-Forwards: 70
      Subject: Performance Test
      Supported: timer
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=user1 53655765 2353687637 IN IP[local_ip_type] [local_ip]
      s=-
      c=IN IP[media_ip_type] [media_ip]
      t=0 0
      m=audio [media_port] RTP/AVP 0 101
      a=rtpmap:0 PCMU/8000
      a=rtpmap:101 telephone-event/8000/1
    ]]>
  </send>

         
  <recv response="100"
        optional="true">
  </recv>

  <recv response="180" optional="true">
  </recv>

  <recv response="183" optional="true">
  </recv>

  <!-- By adding rrs="true" (Record Route Sets), the route sets         -->
  <!-- are saved and used for following messages sent. Useful to test   -->
  <!-- against stateful SIP proxies/B2BUAs.                             -->
  <recv response="200" rtd="true">
      <action>
                <!--<ereg regexp="sip:.*@([0-9A-Za-z\.]+):([0-9]+);transport=([A-Za-z\.]+)"  search_in="hdr" header="Contact:" check_it="true" assign_to="okcontact" /> -->
                <ereg regexp="sip:.*@([0-9A-Za-z\.:]+);transport=([A-Za-z\.]+)"  search_in="hdr" header="Contact:" check_it="true" assign_to="okcontact" />
                <!--<ereg regexp=".*"  search_in="hdr" header="Contact:" check_it="true" assign_to="okcontact" />                                               -->
                <!--ereg regexp=".*"  search_in="hdr" header="Record-Route:" check_it="true" assign_to="okrroute" /> -->
                <ereg regexp="200 OK.*" search_in="msg"  assign_to="1"/>
      </action>
  </recv>

  <!-- Packet lost can be simulated in any send/recv message by         -->
  <!-- by adding the 'lost = "10"'. Value can be [1-100] percent.       -->
  <send>
    <![CDATA[

      ACK [$okcontact] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
      From: [field0] <sip:[field0]@[local_ip]:[local_port]>;tag=[pid]SIPpTag00[call_number]
      To: sut <sip:[field1]@[remote_ip]:[remote_port]>[peer_tag_param]
      Call-ID: [call_id]
      CSeq: [cseq] ACK
      Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport]>
      Max-Forwards: 70
      Subject: Performance Test
      Content-Length: [len]

    ]]>
  </send>

  <sendCmd>
     <![CDATA[
     Call-ID: [call_id]
     [$1]
      ]]>
  </sendCmd>

  <recv request="BYE">
  </recv>

  <send>
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0

    ]]>
  </send>


  <!-- Keep the call open for a while in case the 200 is lost to be     -->
  <!-- able to retransmit it if we receive the BYE again.               -->


  <!-- definition of the response time repartition table (unit is ms)   -->
  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>

  <!-- definition of the call length repartition table (unit is ms)     -->
  <CallLengthRepartition value="10, 50, 100, 500, 1000, 5000, 10000"/>


</scenario>

                                  