<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<scenario>


<!-- SIPPTA_VERSION2 --> 
<nop> 
<action>
<assign assign_to="localCseqNum" value="1" />
<assignstr assign_to="localCseq" value="[$localCseqNum]" />
<ereg regexp="[0-9]+" search_in="var" variable="localCseq" assign_to="localCseq" check_it="true" />

<assign assign_to="localRseqNum" value="0" />
<assignstr assign_to="localRseq" value="[$localRseqNum]" />
<ereg regexp="[0-9]+" search_in="var" variable="localRseq" assign_to="localRseq" check_it="true" />

<assign assign_to="sdpVersionNum" value="1" />
<assignstr assign_to="sdpVer" value="[$sdpVersionNum]" />
<ereg regexp="[0-9]+" search_in="var" variable="sdpVer" assign_to="sdpVer" check_it="true" />

<assignstr assign_to="sdpVer" value="1" />
<ereg regexp="[0-9]+" search_in="var" variable="sdpVer" assign_to="sdpVer" check_it="true" />

<assignstr assign_to="domain" value="[field2]" />
<assignstr assign_to="uriType" value="[field3]" />
<assignstr assign_to="localTransport" value="[field4]" />
<assignstr assign_to="localNo" value="[field0]" />
<assignstr assign_to="remoteNo" value="[field1]" />
<assignstr assign_to="localContact" value="<[$uriType]:[$localNo]@[local_ip]:[local_port];transport=[$localTransport]>" />
<assignstr assign_to="remoteContact" value="[$uriType]:[$remoteNo]@[$domain];transport=[$localTransport]" />
<assignstr assign_to="remoteContactOffHook" value="[$uriType]:[$localNo]@[$domain];avaya-cm-fnu=off-hook;transport=[$localTransport]" />
<assignstr assign_to="remoteContactFNU" value="[$uriType]:[$localNo]@[$domain]" />
<assignstr assign_to="localHdr" value="[$uriType]:[$localNo]@[$domain];tag=1" />
<assignstr assign_to="remoteHdrOffHook" value="<[$uriType]:[$localNo]@[$domain];avaya-cm-fnu=off-hook>" />
<assignstr assign_to="remoteHdrFNU" value="<[$uriType]:[$localNo]@[$domain]>" />
<assignstr assign_to="remoteHdrInitInv" value="[$uriType]:[$remoteNo]@[$domain]" />
<assignstr assign_to="callid2nd" value="A///[call_id]" />
</action>
</nop>

<Reference variables="localRseq" />
<Reference variables="localCseq" />
<Reference variables="remoteNo" />
<Reference variables="domain" />
<Reference variables="sdpVer" />
<Reference variables="uriType" />
<Reference variables="localTransport" />
<Reference variables="localNo" />
<Reference variables="localContact" />
<Reference variables="remoteContact" />
<Reference variables="localHdr" />
<Reference variables="remoteHdrInitInv" />
<Reference variables="remoteHdrOffHook" />
<Reference variables="callid2nd" />
<Reference variables="remoteContactFNU" />
<Reference variables="remoteHdrFNU" />
<Reference variables="remoteContactOffHook" />

<!--CMDEV SIPP DISPLAY NAME:-->

<nop>
<action>
<add assign_to="localCseqNum" value="1" />
<assignstr assign_to="localCseq" value="[$localCseqNum]" />
<ereg regexp="[0-9]+" search_in="var" variable="localCseq" assign_to="localCseq" check_it="true" />
</action>
</nop>


<send retrans="500">
<![CDATA[


PUBLISH [$remoteContact] SIP/2.0
Via: SIP/2.0/[$localTransport] [local_ip]:[local_port];branch=[branch]
From:[$localHdr]
To:[$remoteHdrInitInv]
Call-ID: [call_id]
CSeq: [$localCseq] PUBLISH
Contact: [$localContact]
Allow: INVITE,ACK,BYE,CANCEL,SUBSCRIBE,NOTIFY,MESSAGE,REFER,INFO,PRACK,PUBLISH,UPDATE
  [routes]
Max-Forwards: 70
Subject: Performance Test
Content-Type: application/sdp
Content-Length: [len]


]]>
</send>

<recv response="500">
</recv>

<send>
<![CDATA[

ACK [$remoteContact] SIP/2.0
Via: SIP/2.0/[$localTransport] [local_ip]:[local_port];branch=[branch]
From: [$localHdr]
To:[$remoteHdrInitInv]
Call-ID: [call_id]
CSeq: [$localCseq] ACK
Contact: [$localContact]
  [routes]
  Max-Forwards: 70
  Allow: INVITE,ACK,BYE,CANCEL,SUBSCRIBE,NOTIFY,MESSAGE,REFER,INFO,PRACK,PUBLISH,UPDATE
  Subject: Performance Test
  Content-Type: application/sdp
  Content-Length: [len]

<!--CMDEV SIPP MESSAGE DELIMITOR-->

]]>
</send>
</scenario>
