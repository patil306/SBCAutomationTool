<scenario name="Register as a phone">

  <send retrans="500">
    <![CDATA[

      REGISTER sip:[field2] SIP/2.0
      From: sip:[field0]@[field2];tag=[call_number][local_port]
      To: sip:[field0]@[field2]
      Call-ID: [call_id]
      CSeq: [cseq] REGISTER
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
      Content-Length: 0
      Max-Forwards: 70
      Contact: <sip:[field0]@[local_ip]:[local_port];avaya-sc-enabled;transport=[transport]>;q=1;expires=86400
      User-Agent: Avaya one-X Emulator
      Allow: INVITE,CANCEL,BYE,ACK,SUBSCRIBE,NOTIFY,INFO,REFER,UPDATE

    ]]>
  </send>

  <recv response="401" auth="true">
  </recv>

  <send retrans="500">
    <![CDATA[

      REGISTER sip:[field2] SIP/2.0
      From: sip:[field0]@[field2];tag=[call_number][local_port]
      To: sip:[field0]@[field2]
      Call-ID: [call_id]
      CSeq: [cseq] REGISTER
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
      Content-Length: 0
      Max-Forwards: 70
      Contact: <sip:[field0]@[local_ip]:[local_port];avaya-sc-enabled;transport=[transport]>;q=1;expires=86400
      User-Agent: Avaya one-X Emulator
      Allow: INVITE,CANCEL,BYE,ACK,SUBSCRIBE,NOTIFY,INFO,REFER,UPDATE
      [field3]

    ]]>
  </send>

  <recv response="200" optional="false">
  </recv>


  <!-- definition of the response time repartition table (unit is ms)   -->
  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>

  <!-- definition of the call length repartition table (unit is ms)     -->
  <CallLengthRepartition value="10, 50, 100, 500, 1000, 5000, 10000"/>

  </scenario>


