<!-- Assumes you have already registered the UAS endpoint -->

<scenario name="Basic UAS responder">

  <recv request="INVITE" rrs="true" crlf="true">
        <action>
            <ereg regexp="[0-9]{1,5}" search_in="hdr" header="To:" check_it="true" assign_to="6"/>
            <ereg regexp=".*" search_in="hdr" header="CSeq:" check_it="true" assign_to="7"/>
        </action>
  </recv>

   <nop>
       <action>
         <assignstr assign_to="9" value="[last_Via:]"/>
      </action>
    </nop>

   <nop>
       <action>
         <assignstr assign_to="5" value="[last_Record-Route:]"/>
      </action>
    </nop>


  <!-- The '[last_*]' keyword is replaced automatically by the          -->
  <!-- specified header if it was present in the last message received  -->
  <!-- (except if it was a retransmission). If the header was not       -->
  <!-- present or if no message has been received, the '[last_*]'       -->
  <!-- keyword is discarded, and all bytes until the end of the line    -->
  <!-- are also discarded.                                              -->
  <!--                                                                  -->
  <!-- If the specified header was present several times in the         -->
  <!-- message, all occurences are concatenated (CRLF seperated)        -->
  <!-- to be used in place of the '[last_*]' keyword.                   -->

      <!-- Record-Route: <sip:192.168.10.134:5060;transport=TCP;lr> -->

    <send>
    <![CDATA[
      SIP/2.0 100 Trying
      [last_Via:]
      [last_From:]
      [last_To:];tag=[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0
    ]]>
   </send>

    <send>
    <![CDATA[
      SIP/2.0 180 Ringing
      [last_Via:]
      [last_From:]
      [last_To:];tag=[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      [$5]
      Allow: INVITE,REFER,NOTIFY,UPDATE,SUBSCRIBE,INFO,PRACK
      Require: 100rel
      Supported: 100rel
      Contact: <sip:[$6]@[local_ip]:[local_port];transport=[transport]>
      Content-Length: 0
    ]]>
   </send>

  <pause milliseconds="500"/>

  <send retrans="1500">
    <![CDATA[
      SIP/2.0 200 OK
      [$9]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      CSeq:[$7]
      [$5]
      Allow: INVITE,REFER,NOTIFY,UPDATE,SUBSCRIBE,INFO
      Contact: <sip:[$6]@[local_ip]:[local_port];transport=[transport]>
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=user1 987650 200 IN IP[local_ip_type] [local_ip]
      s=-
      c=IN IP[media_ip_type] [media_ip]
      t=0 0
      m=audio [media_port] RTP/AVP 0 120
      a=rtpmap:0 PCMU/8000
      a=rtpmap:120 telephone-event/8000
    ]]>
  </send>

  <recv request="ACK" rtd="true" crlf="true">
  </recv>

  <recv request="INVITE" rrs="true" crlf="true">
  </recv>

   <send retrans="1500">
    <![CDATA[
      SIP/2.0 200 OK
      [$9]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      CSeq:[$7]
      [$5]
      Allow: INVITE,REFER,NOTIFY,UPDATE,SUBSCRIBE,INFO
      Contact: <sip:[$6]@[local_ip]:[local_port];transport=[transport]>
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=user1 987650 200 IN IP[local_ip_type] [local_ip]
      s=-
      c=IN IP[media_ip_type] [media_ip]
      t=0 0
      m=audio [media_port] RTP/AVP 0 120
      a=rtpmap:0 PCMU/8000
      a=rtpmap:120 telephone-event/8000
    ]]>
  </send>

  <recv request="ACK" rtd="true" crlf="true">
  </recv>

  <recv request="BYE" rrs="true" crlf="true">
  </recv>

   <send>
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [$5]
      [last_CSeq:]
      Contact: <sip:[$6]@[local_ip]:[local_port]>
      Content-Length: 0
    ]]>
   </send>

  <!-- Keep the call open for a while in case the 200 is lost to be     -->
  <!-- able to retransmit it if we receive the BYE again.               -->

  <!-- definition of the response time repartition table (unit is ms)   -->
  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>

  <!-- definition of the call length repartition table (unit is ms)     -->
  <CallLengthRepartition value="10, 50, 100, 500, 1000, 5000, 10000"/>


</scenario>

