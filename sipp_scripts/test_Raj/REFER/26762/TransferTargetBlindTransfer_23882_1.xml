<!-- ACK sip:[service]@[remote_ip]:[remote_port] SIP/2.0 -->

  <send>
    <![CDATA[
      ACK sip:[field1]@[remote_ip]:[remote_port];transport=[transport] SIP/2.0
      [last_Via:]
      From: [$us]
      To: [$them]
      Call-ID: [call_id]
      CSeq: 2 ACK
      Contact: sip:[field0]@[local_ip]:[local_port];transport=[transport]
      Max-Forwards: 70
      [routes]
      Subject: Performance Test
      Content-Length: 0
     ]]>
  </send>

