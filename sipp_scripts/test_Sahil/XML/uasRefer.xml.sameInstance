<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<scenario name="Basic UAS responder">

<!-- By adding rrs="true" (Record Route Sets), the route sets         -->
<!-- are saved and used for following messages sent. Useful to test   -->
<!-- against stateful SIP proxies/B2BUAs.                             -->

<recv request="INVITE" crlf="true">
  <action>
<!--          <ereg regexp="sip.*[^;tag]" search_in="hdr" header="From:" assign_to="1"/> -->
          <ereg regexp="(<?)(sip.*)(>?)(;tag=.*)" search_in="hdr" header="From:" assign_to="5,6"/>
          <ereg regexp="sip.*[^;]" search_in="hdr" header="To:" assign_to="4"/>
   </action>
</recv>
<Reference variables="5,6" />

  
<!-- The '[last_*]' keyword is replaced automatically by the          -->
<!-- specified header if it was present in the last message received  -->
<!-- (except if it was a retransmission). If the header was not       -->
<!-- present or if no message has been received, the '[last_*]'       -->
<!-- keyword is discarded, and all bytes until the end of the line    -->
<!-- are also discarded.                                              -->
<!--                                                                  -->
<!-- If the specified header was present several times in the         -->
<!-- message, all occurences are concatenated (CRLF seperated)        -->
<!-- to be used in place of the '[last_*]' keyword.                   -->

<send>
<![CDATA[
SIP/2.0 100 Trying
[last_Via:]
[last_From:]
[last_To:]
[last_Call-ID:]
[last_CSeq:]
Contact: <sip:[local_ip]:[local_port];transport=[transport]>
Content-Length: 0
]]>
</send>

<send>
<![CDATA[
SIP/2.0 180 Ringing
[last_Via:]
[last_From:]
[last_To:];tag=[pid]SIPpTag00[call_number]
[last_Call-ID:]
[last_CSeq:]
Contact: <sip:[local_ip]:[local_port];transport=[transport]>
Content-Length: 0
]]>
</send>

<send retrans="500">
<![CDATA[
SIP/2.0 200 OK
[last_Via:]
[last_From:]
[last_To:];tag=[pid]SIPpTag00[call_number]
[last_Call-ID:]
[last_CSeq:]
Contact: <sip:[local_ip]:[local_port];transport=[transport]>
Av-Global-Session-ID: 00fe2c47-42d9-4801-9379-5b83ad7d0000
Content-Type: application/sdp
Content-Length: [len]

v=0
o=user1 53655765 2353687637 IN IP[local_ip_type] [local_ip]
s=-
c=IN IP[media_ip_type] [media_ip]
t=0 0
m=audio [media_port] RTP/AVP 0
a=rtpmap:0 PCMU/8000
]]>
</send>

<recv request="ACK" rtd="true" crlf="true">
    <action>
          <ereg regexp=".*" search_in="hdr" header="From:" assign_to="2"/>
          <ereg regexp=".*" search_in="hdr" header="To:" assign_to="3"/>
    </action>
</recv>
<Reference variables="2,3" />


<!-- Send REFER towards SBC to transfer the call to the Agent -->
<pause milliseconds="2000"/>

<send retrans="500">
<![CDATA[

REFER sip:[field0]@[remote_ip]:[remote_port];transport=[transport] SIP/2.0
Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
From: [$3]
To: [$2]
Call-ID: [call_id]
CSeq: 7 REFER
Refer-To: <sip:50005@192.168.5.12:6025;transport=[transport]>
Referred-By: [$4]
Contact: <sip:[local_ip]:[local_port];transport=[transport]>
Content-Length: 0

]]>
 </send>

<recv response="202" optional="true">
  </recv>

<recv request="NOTIFY" crlf="true">
</recv>


  <send >
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag00[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[local_ip]:[local_port];transport=[transport]>
      Content-Type: application/sdp
      Content-Length: 0

    ]]>
  </send>


<recv request="INVITE" crlf="true">
  <action>
<!--          <ereg regexp="sip.*[^;tag]" search_in="hdr" header="From:" assign_to="1"/> -->
          <ereg regexp="(<?)(sip.*)(>?)(;tag=.*)" search_in="hdr" header="From:" assign_to="7,8"/>
          <ereg regexp="sip.*[^;]" search_in="hdr" header="To:" assign_to="9"/>
<!--           <ereg regexp="*" search_in="hdr" header="Call-ID:" assign_to="10"/> -->
   </action>
</recv>
<Reference variables="7,8,9" />




<send>
<![CDATA[
SIP/2.0 100 Trying
[last_Via:]
From: [$7]
To: [$9]
[last_Call-ID:]
[last_CSeq:]
Contact: <sip:[local_ip]:[local_port];transport=[transport]>
Content-Length: 0
]]>
</send>

<send retrans="500">
<![CDATA[
SIP/2.0 200 OK
[last_Via:]
From: [$7]
To: [$9]
[last_Call-ID:]
[last_CSeq:]
Contact: <sip:[local_ip]:[local_port];transport=[transport]>
Av-Global-Session-ID: 00fe2c47-42d9-4801-9379-5b83ad7d0000
Content-Type: application/sdp
Content-Length: [len]

v=0
o=user1 53655821 2353687637 IN IP[local_ip_type] [local_ip]
s=-
c=IN IP[media_ip_type] [media_ip]
t=0 0
m=audio [media_port] RTP/AVP 0
a=rtpmap:0 PCMU/8000
]]>
</send>

<recv request="ACK" rtd="true" crlf="true">
    <action>
          <ereg regexp=".*" search_in="hdr" header="From:" assign_to="11"/>
          <ereg regexp=".*" search_in="hdr" header="To:" assign_to="12"/>
    </action>
</recv>
<Reference variables="11,12" />

<recv request="BYE">
    <action>
      <ereg regexp=": *(.*)" search_in="hdr" header="CSeq" assign_to="_,Bye1Cseq"/>
      <ereg regexp=": *(.*)" search_in="hdr" header="From" assign_to="_,Bye1From"/>
      <ereg regexp=": *(.*)" search_in="hdr" header="To" assign_to="_,Bye1To"/>
    </action>
</recv>


<pause milliseconds="500"/>

<send>
<![CDATA[

SIP/2.0 200 OK
[last_Via:]
From: [$Bye1From]
To: [$Bye1To]
[last_Call-ID:]
CSeq: [$Bye1Cseq]
Contact: <sip:[local_ip]:[local_port];transport=[transport]>
Content-Length: 0

]]>
</send>


<recv request="BYE">
    <action>
      <ereg regexp=": *(.*)" search_in="hdr" header="CSeq" assign_to="_,Bye1Cseq"/>
      <ereg regexp=": *(.*)" search_in="hdr" header="From" assign_to="_,Bye1From"/>
      <ereg regexp=": *(.*)" search_in="hdr" header="To" assign_to="_,Bye1To"/>
    </action>
</recv>


<pause milliseconds="500"/>

<send>
<![CDATA[

SIP/2.0 200 OK
[last_Via:]
From: [$7]
To: [$9]
[last_Call-ID:]
CSeq: [$Bye1Cseq]
Contact: <sip:[local_ip]:[local_port];transport=[transport]>
Content-Length: 0

]]>
</send>


</scenario>
