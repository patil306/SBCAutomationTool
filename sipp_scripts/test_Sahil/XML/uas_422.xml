<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!-- This program is free software; you can redistribute it and/or      -->

<scenario name="RTP Echo pause / start test UAS">
<!-- In client mode (sipp placing calls), the Call-ID MUST be         -->
  <recv request="INVITE" rrs="true"/>

  <send>
    <![CDATA[

      SIP/2.0 100 Trying
      [last_Via:]
      [last_Record-Route:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: sip:[field1]@[local_ip]:[local_port];transport=[transport]
      Content-Length: 0

    ]]>
  </send>

  <pause milliseconds="100"/>

  <send retrans="500">
    <![CDATA[

      SIP/2.0 422 Interval too brief
      [last_Via:]
      [last_Record-Route:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: [len]

    ]]>
  </send>


  <recv request="ACK" rrs="true">
  </recv>

</scenario><!-- vim: set ts=8 sw=2 sts=2 et ai: -->
