<scenario name="Basic Sipstone UAC">
  <!-- In client mode (sipp placing calls), the Call-ID MUST be         -->
  <!-- generated by sipp. To do so, use [call_id] keyword.                -->
  <send retrans="500">
    <![CDATA[

      REGISTER sip:[field0]@[field2];transport=[transport] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[field5]
      From: <sip:[field0]@[field2]>;tag=[pid]SIPpTag01[call_number]
      To: <sip:[field0]@[field2]>
      Call-ID: REGISTER///[call_id]
      User-Agent: pqrxyz
      CSeq: [cseq] REGISTER
      Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport];avaya-sc-enabled>;q=1;expires=120;+avaya.gmtoffset="0:00";+avaya.js-ver="1.0";+avaya.model="n/a";+avaya.sn="n/a";+avaya.firmware="n/a";+sip.instance="<urn:uuid:0da99e27-89ad-f8a0-1762-4e2a9b52e4df>";reg-id=1
      Max-Forwards: 70
      Supported: eventlist,feature-ref,replaces,tdialog
      Allow: INVITE,ACK,BYE,CANCEL,SUBSCRIBE,NOTIFY,MESSAGE,REFER,INFO,PUBLISH,UPDATE
      Content-Length: 0

    ]]>
  </send>

   <recv response="100" optional="true">
   </recv>

   <recv response="401" rtd="true">
   </recv>

  <send retrans="500">
    <![CDATA[

      REGISTER sip:[field0]@[field2];transport=[transport] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[field6]
      From: <sip:[field0]@[field2]>;tag=[pid]SIPpTag01[call_number]
      To: <sip:[field0]@[field2]>
      Call-ID: REGISTER///[call_id]
      User-Agent: pqrxyz
      CSeq: [cseq] REGISTER
      Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport];avaya-sc-enabled>;q=1;expires=120;+avaya.gmtoffset="0:00";+avaya.js-ver="1.0";+avaya.model="n/a";+avaya.sn="n/a";+avaya.firmware="n/a";+sip.instance="<urn:uuid:0da99e27-89ad-f8a0-1762-4e2a9b52e4df>";reg-id=1
      Max-Forwards: 70
      Authorization: Digest realm="hautelook.local",nonce="16d6523f8425d0d479e886d8de76a0112f8f452162f",uri="sips:hautelook.local",opaque="1234567890abcedef",qop=auth,response="038bc7b1f8656a106fcaa7c4cf2c0fca",username="11006002532",cnonce="0a4f113b",nc=00000001
      Supported: eventlist,feature-ref,replaces,tdialog
      Allow: INVITE,ACK,BYE,CANCEL,SUBSCRIBE,NOTIFY,MESSAGE,REFER,INFO,PUBLISH,UPDATE
      Content-Length: 0

    ]]>
  </send>

   <recv response="100" optional="true">
   </recv>

   <recv response="200" rtd="true">
   </recv>

  <!--pause milliseconds="8000"/ -->
   <send retrans="500">
    <![CDATA[

      SUBSCRIBE sip:[field0]@[field2];transport=[transport] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[field6]
      From: <sip:[field0]@[field2]>;tag=[pid]SIPpTag01[call_number]
      To:  <sip:[field0]@[field2]>
      Call-ID: SUBSCRIBECMF///[call_id]
      CSeq: 1 SUBSCRIBE
      Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport]>
      Event: avaya-cm-feature-status
      Expires: 3600
      Max-Forwards: 70
      User-Agent: Sipp2.0
      Subject: Performance Test
      Content-Length: 0

    ]]>
  </send>

  <recv response="100" optional="true">
  </recv>

  <recv response="200" rtd="true">
  </recv>

  <recv request="NOTIFY" rtd="true" crlf="true">
  </recv>

  <send>
    <![CDATA[

	SIP/2.0 200 OK
        [last_Via:]
        [last_From:]
        [last_To:];tag=[pid]SIPpTag01[call_number]
        [last_Call-ID:]
        Expires: 3600
        [last_CSeq:]
        [last_Contact:]
        Content-Length: 0

    ]]>
  </send>

   <send retrans="500">
    <![CDATA[

      SUBSCRIBE sip:[field0]@[field2];transport=[transport] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[field6]
      From: <sip:[field0]@[field2]>;tag=[pid]SIPpTag01[call_number]
      To: <sip:[field0]@[field2]>
      Call-ID: SUBSCRIBEMS///[call_id]
      CSeq: 2 SUBSCRIBE
      Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport]>
      Event: message-summary
      Expires: 3600
      Max-Forwards: 70
      User-Agent: Sipp2.0
      Subject: Performance Test
      Content-Length: 0

    ]]>
  </send>

  <recv response="100" optional="true">
  </recv>

  <recv response="200" rtd="true">
  </recv>

  <recv request="NOTIFY" rtd="true" crlf="true">
  </recv>

  <send>
    <![CDATA[

	SIP/2.0 200 OK
        [last_Via:]
        [last_From:]
        [last_To:];tag=[pid]SIPpTag01[call_number]
        [last_Call-ID:]
        Expires: 3600
        [last_CSeq:]
        [last_Contact:]
        Content-Length: 0

    ]]>
  </send>

   <send retrans="500">
    <![CDATA[

      SUBSCRIBE sip:[field0]@[field2];transport=[transport] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[field6]
      From: <sip:[field0]@[field2]>;tag=[pid]SIPpTag01[call_number]
      To: <sip:[field0]@[field2]>
      Call-ID: SUBSCRIBECCS///[call_id]
      CSeq: 3 SUBSCRIBE
      Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport]>
      Event: avaya-ccs-profile
      Expires: 3600
      Max-Forwards: 70
      User-Agent: Sipp2.0
      Subject: Performance Test
      Content-Length: 0

    ]]>
  </send>

  <recv response="100" optional="true">
  </recv>

  <recv response="200" rtd="true">
  </recv>

  <recv request="NOTIFY" rtd="true" crlf="true">
  </recv>

  <send>
    <![CDATA[

	SIP/2.0 200 OK
        [last_Via:]
        [last_From:]
        [last_To:];tag=[pid]SIPpTag01[call_number]
        [last_Call-ID:]
        Expires: 3600
        [last_CSeq:]
        [last_Contact:]
        Content-Length: 0

    ]]>
  </send>

   <send retrans="500">
    <![CDATA[

      SUBSCRIBE sip:[field0]@[field2];transport=[transport] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[field6]
      From: <sip:[field0]@[field2]>;tag=[pid]SIPpTag01[call_number]
      To: <sip:[field0]@[field2]>
      Call-ID: SUBSCRIBEDIA///[call_id]
      CSeq: 4 SUBSCRIBE
      Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport]>
      Event: dialog
      Expires: 3600
      Max-Forwards: 70
      User-Agent: Sipp2.0
      Subject: Performance Test
      Content-Length: 0

    ]]>
  </send>

  <recv response="100" optional="true">
  </recv>

  <recv response="200" rtd="true">
  </recv>

  <recv request="NOTIFY" rtd="true" crlf="true">
  </recv>

  <send>
    <![CDATA[

	SIP/2.0 200 OK
        [last_Via:]
        [last_From:]
        [last_To:];tag=[pid]SIPpTag01[call_number]
        [last_Call-ID:]
        Expires: 3600
        [last_CSeq:]
        [last_Contact:]
        Content-Length: 0

    ]]>
  </send>

   <send retrans="500">
    <![CDATA[

      SUBSCRIBE sip:[field0]@[field2];transport=[transport] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[field6]
      From: <sip:[field0]@[field2]>;tag=[call_number]
      To: <sip:[field0]@[field2]>
      Call-ID: SUBSCRIBEREG///[call_id]
      CSeq: 5 SUBSCRIBE
      Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport]>
      Event: reg
      Expires: 3600
      Max-Forwards: 70
      User-Agent: Sipp2.0
      Subject: Performance Test
      Content-Length: 0

    ]]>
  </send>

  <recv response="100" optional="true">
  </recv>

  <recv response="200" rtd="true">
  </recv>

  <recv request="NOTIFY" rtd="true" crlf="true">
  </recv>

  <send>
    <![CDATA[

	SIP/2.0 200 OK
        [last_Via:]
        [last_From:]
        [last_To:];tag=[pid]SIPpTag01[call_number]
        [last_Call-ID:]
        Expires: 3600
        [last_CSeq:]
        [last_Contact:]
        Content-Length: 0

    ]]>
  </send>

  <!-- definition of the response time repartition table (unit is ms)   -->
  <send retrans="500">
    <![CDATA[

      REGISTER sip:[field0]@[field2];transport=[transport] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[field5]
      From: <sip:[field0]@[field2]>;tag=[pid]SIPpTag01[call_number]
      To: <sip:[field0]@[field2]>
      Call-ID: REGISTER///[call_id]
      User-Agent: pqrxyz
      CSeq: [cseq] REGISTER
      Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport];avaya-sc-enabled>;q=1;expires=1800;+avaya.gmtoffset="0:00";+avaya.js-ver="1.0";+avaya.model="n/a";+avaya.sn="n/a";+avaya.firmware="n/a";+sip.instance="<urn:uuid:0da99e27-89ad-f8a0-1762-4e2a9b52e4df>";reg-id=1
      Max-Forwards: 70
      Supported: eventlist,feature-ref,replaces,tdialog
      Allow: INVITE,ACK,BYE,CANCEL,SUBSCRIBE,NOTIFY,MESSAGE,REFER,INFO,PUBLISH,UPDATE
      Content-Length: 0

    ]]>
  </send>

   <recv response="100" optional="true">
   </recv>

   <recv response="200" rtd="true">
   </recv>
  <!-- definition of the response time repartition table (unit is ms)   -->
  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>

  <!-- definition of the call length repartition table (unit is ms)     -->
  <CallLengthRepartition value="10, 50, 100, 500, 1000, 5000, 10000"/>


</scenario>

