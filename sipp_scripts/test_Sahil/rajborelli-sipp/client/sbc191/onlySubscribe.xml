<scenario name="Basic Sipstone UAC">
  <!-- In client mode (sipp placing calls), the Call-ID MUST be         -->
  <!-- generated by sipp. To do so, use [call_id] keyword.                -->



   <send retrans="500">
    <![CDATA[

      SUBSCRIBE sip:[field0]@[field2];transport=[transport] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[field6]
      From: <sip:[field0]@[field2]>;tag=[call_number]
      To:  <sip:[field0]@[field2]>
      Call-ID: SUBSCRIBECMF///[call_id]
      CSeq: 1 SUBSCRIBE
      Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport]>
      Event: avaya-cm-feature-status
      Expires: 150
      Max-Forwards: 70
      User-Agent: Sipp2.0
      Subject: Performance Test
      Content-Length: 0

    ]]>
  </send>

  <recv response="100" optional="true">
  </recv>

  <recv response="200" rtd="true">
  </recv>


  <recv request="NOTIFY" rtd="true" crlf="true">
  </recv>

  <send>
    <![CDATA[

        SIP/2.0 200 OK
        [last_Via:]
        [last_From:]
        [last_To:];tag=[call_number]
        [last_Call-ID:]
        Expires: 3600
        [last_CSeq:]
        [last_Contact:]
        Content-Length: 0

    ]]>
  </send>


   <send retrans="500">
    <![CDATA[

      SUBSCRIBE sip:[field0]@[field2];transport=[transport] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[field6]
      From: <sip:[field0]@[field2]>;tag=[call_number]
      To: <sip:[field0]@[field2]>
      Call-ID: SUBSCRIBEMS///[call_id]
      CSeq: 2 SUBSCRIBE
      Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport]>
      Event: message-summary
      Expires: 150
      Max-Forwards: 70
      User-Agent: Sipp2.0
      Subject: Performance Test
      Content-Length: 0

    ]]>
  </send>

  <recv response="100" optional="true">
  </recv>

  <recv response="200" rtd="true">
  </recv>

  <recv request="NOTIFY" rtd="true" crlf="true">
  </recv>

  <send>
    <![CDATA[

        SIP/2.0 200 OK
        [last_Via:]
        [last_From:]
        [last_To:];tag=[call_number]
        [last_Call-ID:]
        Expires: 3600
        [last_CSeq:]
        [last_Contact:]
        Content-Length: 0

    ]]>
  </send>




  <!-- definition of the response time repartition table (unit is ms)   -->
  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>

  <!-- definition of the call length repartition table (unit is ms)     -->
  <CallLengthRepartition value="10, 50, 100, 500, 1000, 5000, 10000"/>


</scenario>

