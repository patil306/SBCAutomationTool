<scenario name="Basic UAS responder">
  <!-- By adding rrs="true" (Record Route Sets), the route sets         -->
  <!-- are saved and used for following messages sent. Useful to test   -->
  <!-- against stateful SIP proxies/B2BUAs.                             -->

  <!-- The '[last_*]' keyword is replaced automatically by the          -->
  <!-- specified header if it was present in the last message received  -->
  <!-- (except if it was a retransmission). If the header was not       -->
  <!-- present or if no message has been received, the '[last_*]'       -->
  <!-- keyword is discarded, and all bytes until the end of the line    -->
  <!-- are also discarded.                                              -->
  <!--                                                                  -->
  <!-- If the specified header was present several times in the         -->
  <!-- message, all occurences are concatenated (CRLF seperated)        -->
  <!-- to be used in place of the '[last_*]' keyword.                   -->



  <recv request="SUBSCRIBE">
  </recv>

  <send>
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:];tag=[call_number]
      [last_Call-ID:]
      Expires: 3600
      [last_CSeq:]
      Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport]>
      Content-Length: 0

    ]]>
  </send>


   <pause/>

  <send>
    <![CDATA[

        NOTIFY sip:[field0]@[field4];transport=[transport];[field3] SIP/2.0
        Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
        From: <sip:[field0]@[field2]>;tag=[call_number]
        To: <sip:[field0]@[field2]>;tag=[call_number]
        Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport]>
        [last_Call-ID:]
        Subscription-State: active;expires=300
        Event: avaya-cm-feature-status
        Content-Type: application/avaya-cm-feature-status+xml
        CSeq: 1 NOTIFY
        Content-Length: [len]

        <?xml version="1.0"?>
        <feature-status entity="sip:pkupgrp_0@[field2]" version="0" state="full"">
        <feature name="group-call-pickup" status="off">
        </feature>
        </feature-status>

    ]]>
  </send>

  <recv response="200">
  </recv>


  <recv request="SUBSCRIBE">
  </recv>

  <send>
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:];tag=[call_number]
      [last_Call-ID:]
      Expires: 3600
      [last_CSeq:]
      Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport]>
      Content-Length: 0

    ]]>
  </send>

  <pause/>


  <send>
    <![CDATA[

        NOTIFY sip:[field0]@[field4];transport=[transport];[field3] SIP/2.0
        Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
        From: <sip:[field0]@[field2]>;tag=[call_number]
        To: <sip:[field0]@[field2]>;tag=[call_number]
        Contact: <sip:[field0]@[local_ip]:[local_port];transport=[transport]>
        [last_Call-ID:]
        Subscription-State: active;expires=300
        Event: message-summary
        Content-Type: application/simple-message-summary
        CSeq: 2 NOTIFY
        Content-Length: 68

        Messages-Waiting: no
        Message-Account: sip:5112141005@multism2.com

    ]]>
  </send>

  <recv response="200">
  </recv>


  <!-- Keep the call open for a while in case the 200 is lost to be     -->
  <!-- able to retransmit it if we receive the BYE again.               -->


  <!-- definition of the response time repartition table (unit is ms)   -->
  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>

  <!-- definition of the call length repartition table (unit is ms)     -->
  <CallLengthRepartition value="10, 50, 100, 500, 1000, 5000, 10000"/>

</scenario>

