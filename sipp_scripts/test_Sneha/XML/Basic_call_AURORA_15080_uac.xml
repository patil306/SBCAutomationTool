<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!--      Sipp default 'uac' scenario.   -->
<!--      User-to-User: 00FA080001001056965CFB;encoding=hex -->

<scenario name="Basic Sipstone UAC">

<send retrans="500">
<![CDATA[
  INVITE sip:[field1]@[remote_ip]:[remote_port];transport=[transport] SIP/2.0
  Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
  From: sip:[field0]@[local_ip];tag=[call_number]
  To: sip:[field1]@[remote_ip]:[remote_port]
  Call-ID: [call_id]
  CSeq: 1 INVITE
  Contact: <sip:[local_ip]:[local_port];transport=[transport]>
  Supported: replaces
  Max-Forwards: 70
  Subject: Performance Test
  User-to-User: 00FA080001001056965CFB;encoding=hex
  Content-Type: application/sdp
  Content-Length: [len]
  
  v=0
  o=user1 53655765 2353687637 IN IP[local_ip_type] [local_ip]
  s=SBC call
  c=IN IP[media_ip_type] [media_ip]
  t=0 0
  m=audio 10660 RTP/AVP 18 18 8 0 108
  a=fmtp:18 annexb=yes
  a=fmtp:18 annexb=no
  a=rtpmap:108 telephone-event/16000
  a=fmtp:108 0-15
  a=ptime:20
  a=sendrecv
]]>
</send>

<!-- SDP
  m=audio 10660 RTP/AVP 18 18 8 0 108
  a=fmtp:18 annexb=yes
  a=fmtp:18 annexb=no
     -->

<recv response="100" optional="true">
</recv>

<recv response="180" optional="true">
</recv>

<!-- By adding rrs="true" (Record Route Sets), the route sets         -->
<!-- are saved and used for following messages sent. Useful to test   -->
<!-- against stateful SIP proxies/B2BUAs.                             -->

<recv response="200" rrs="true">
  <!--      <action>
                   <ereg regexp="sip.*[^>]" search_in="hdr" header="Contact:" assign_to="1"/>
                           </action> -->
                           </recv> 
<!-- Packet lost can be simulated in any send/recv message by         -->
<!-- by adding the 'lost = "10"'. Value can be [1-100] percent.       -->
<!-- ACK sip:[service]@[remote_ip]:[remote_port] SIP/2.0 -->

<send retrans="500">
<![CDATA[
  ACK sip:[field1]@[remote_ip]:[remote_port];transport=[transport] SIP/2.0
  Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=z9hG4bK-s1632-001817380035-1--s1632-
  From: sip:[field0]@[local_ip];tag=[call_number]
  To: sip:[field1]@[remote_ip]:[remote_port][peer_tag_param]
  Route: <sips:[remote_ip]:[remote_port];transport=[transport];lr;ipcs-line=3234>
  Call-ID: [call_id]
  CSeq: 1 ACK
  Max-Forwards: 70
  Subject: Performance Test
  Content-Length: 0
 ]]>
</send>



