<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!--      Sipp default 'uac' scenario.   -->
<!--      User-to-User: 00FA080001001056965CFB;encoding=hex -->

<scenario name="Basic Sipstone UAC">

<send retrans="500">
<![CDATA[
  INVITE sips:[field1]@[remote_ip] SIP/2.0
  Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
  From: sips:[field0]@[local_ip];tag=[call_number]
  To: sips:[field1]@[remote_ip]:[remote_port]
  Call-ID: [call_id]
  CSeq: [cseq] INVITE
  Contact: sips:[field0]@[local_ip]:[local_port];transport=TLS
  Supported: replaces
  Max-Forwards: 70
  Subject: Performance Test
  User-to-User: 00FA080001001056965CFB;encoding=hex
  Content-Type: application/sdp
  Content-Length: [len]
  
  v=0
  o=sips:66070417@20.20.64.92 2 2 IN IP4 20.20.64.92
  s=-
  c=IN IP4 20.20.64.92
  b=TIAS:576000
  a=activetalker:1
  t=0 0
  m=audio 5004 RTP/AVP 116 9 8 0 110 18 109
  a=sendrecv
  a=ptime:20
  a=rtpmap:116 OPUS/48000/2
  a=fmtp:116 maxplaybackrate=16000; sprop-maxcapturerate=16000; maxaveragebitrate=20000; stereo=0; sprop-stereo=0; cbr=0; useinbandfec=0; usedtx=0
  a=minptime:20
  a=maxptime:20
  a=rtpmap:9 G722/8000/1
  a=rtpmap:8 PCMA/8000/1
  a=rtpmap:0 PCMU/8000/1
  a=rtpmap:110 G726-32/8000/1
  a=rtpmap:18 G729/8000/1
  a=rtpmap:109 telephone-event/8000
]]>
</send>

<recv response="100" optional="true">
</recv>
