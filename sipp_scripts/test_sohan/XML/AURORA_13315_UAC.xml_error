[last_From:]
[last_To:];tag=76946b8185741e881e005056904b1b
[last_Call-ID:]
[last_CSeq:]
Contact: <sips:[local_ip]:[local_port];transport=[transport]>
Content-Type: application/sdp
Content-Length: [len]

v=0                                                                                                             
o=- 1519362456 2 IN IP4 10.133.67.25                                                                            
s=-                                                                                                             
