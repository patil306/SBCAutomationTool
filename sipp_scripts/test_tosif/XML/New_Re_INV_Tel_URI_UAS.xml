<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<scenario name="Basic UAS responder">

<!-- By adding rrs="true" (Record Route Sets), the route sets         -->
<!-- are saved and used for following messages sent. Useful to test   -->
<!-- against stateful SIP proxies/B2BUAs.                             -->

<recv request="INVITE" crlf="true">
</recv>
  
<!-- The '[last_*]' keyword is replaced automatically by the          -->
<!-- specified header if it was present in the last message received  -->
<!-- (except if it was a retransmission). If the header was not       -->
<!-- present or if no message has been received, the '[last_*]'       -->
<!-- keyword is discarded, and all bytes until the end of the line    -->
<!-- are also discarded.                                              -->
<!--                                                                  -->
<!-- If the specified header was present several times in the         -->
<!-- message, all occurences are concatenated (CRLF seperated)        -->
<!-- to be used in place of the '[last_*]' keyword.                   -->

<send>
<![CDATA[
SIP/2.0 100 Trying
[last_Via:]
[last_From:]
[last_To:]
[last_Call-ID:]
[last_CSeq:]
Contact: <sip:192.168.6.5:5065;transport=TCP>
Content-Length: 0
]]>
</send>

<send>
<![CDATA[
SIP/2.0 180 Ringing
[last_Via:]
[last_From:]
[last_To:];tag=[call_number]1
[last_Call-ID:]
[last_CSeq:]
Content-Length: 0
]]>
</send>


  <send retrans="500">
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:];tag=[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: "Ext 6010" <sip:+60322026010@;[local_ip]:[local_port];transport=[transport];gsid=0d090830-8356-11e5-a980-000c2988f3ac>
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=user1 53655765 2353687637 IN IP[local_ip_type] [local_ip]
      s=-
      c=IN IP[media_ip_type] [media_ip]
      t=0 0
      m=audio [media_port] RTP/AVP 0
      a=rtpmap:0 PCMU/8000
    ]]>
  </send>

<recv request="ACK"  rtd="true" crlf="true">
<action>
          <ereg regexp="(<?)(sip.*)(>?)" search_in="hdr" header="Contact:" assign_to="1,2,3"/>
</action>
</recv>
<Reference variables="1,2" />

<pause milliseconds="3000"/>

<!--  Send RE-INVITE to UAC -->


<send retrans="500">
  <![CDATA[
    INVITE [$3] SIP/2.0
    From: <sip:+60-3-22026010@192.168.6.5:5065;user=phone>;tag=[call_number]
    To: <sip:Anonymous@ims.tm.com.my;cpc=Unknown>;tag=x0hxzrih-CC-148 
    Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
    [last_Call-ID:]
    Cseq: 1 INVITE
    Contact: "Ext 6010" <sip:+60322026010@[local_ip]:[local_port];transport=[transport];gsid=0d090830-8356-11e5-a980-000c2988f3ac>
    Content-Length: [len]

     v=0
     o=user1 53655765 2353687637 IN IP[local_ip_type] [local_ip]
     s=-
     c=IN IP[media_ip_type] [media_ip]
     t=0 0
     m=audio [media_port] RTP/AVP 0
     a=rtpmap:0 PCMU/8000
    ]]>
  </send>

<recv response="200" rtd="true">
</recv>

<send>
    <![CDATA[
      ACK [$3] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
      From: <sip:+60-3-22026010@192.168.6.5:5065;user=phone>;tag=[call_number]
      To: <sip:Anonymous@ims.tm.com.my;cpc=Unknown>;tag=x0hxzrih-CC-148 
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
      [last_Call-ID:]
      CSeq: 1 ACK
      Max-Forwards: 70
      Subject: Performance Test
      Content-Length: 0
      ]]>
      </send>


<recv request="BYE">
</recv>

<send>
<![CDATA[
SIP/2.0 200 OK
[last_Via:]
[last_From:]
[last_To:]
[last_Call-ID:]
[last_CSeq:]
Contact: "Ext 6010" <sip:+60322026010@[local_ip]:[local_port];transport=[transport];gsid=0d090830-8356-11e5-a980-000c2988f3ac>
Content-Length: 0
]]>
</send>


</scenario>
