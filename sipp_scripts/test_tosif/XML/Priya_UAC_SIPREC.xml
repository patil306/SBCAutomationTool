<scenario name="Basic Sipstone UAC">
  <!-- In client mode (1111 placing calls), the Call-ID MUST be         -->
  <!-- generated by 1111. To do so, use [call_id] keyword.                -->
  <send>
    <![CDATA[

      INVITE sip:[service]@[remote_ip];phone-context=1112;user=phone SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
      From: sipp <sip:1111@[local_ip]>;phone-context=1112;user=phone;tag=[call_number]
      To: sut <sip:[service]@192.168.5.32;phone-context=1112>
      Call-ID: [call_id]
      CSeq: 1 INVITE
      Contact: <sip:1111@[local_ip]:[local_port];transport=tcp>
      Max-Forwards: 70
      Subject: Performance Test
      P-Asserted-Identity: "Cullen Jennings" <sip:fluffy@avaya.com> 
      Content-Type: application/sdp
      Content-Length: [len]
      Supported: Route, Path, Service-Route, 100rel

      v=0
      o=user1 53655765 2353687637 IN IP[local_ip_type] [local_ip]
      s=-
      c=IN IP[media_ip_type] [media_ip]
      t=0 0
      m=audio [media_port] RTP/AVP 0
      a=rtpmap:0 PCMU/8000
      a=sendonly

    ]]>
  </send>
<!--
P-Preferred-Identity: 1111 <sip:1111@10.201.1.164>
-->
  <recv response="100">
  </recv>
 <recv response="180">
  </recv>
	
