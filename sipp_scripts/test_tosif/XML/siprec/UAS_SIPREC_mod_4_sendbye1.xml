--> 
<scenario name="Basic UAS responder">

<recv request="INVITE" crlf="true">
        <action>
                <ereg regexp=".*" search_in="hdr" header="Record-Route:" check_it="true" assign_to="5"/>
                <!--    <ereg regexp=".*" search_in="hdr" header="Via:" check_it="true" assign_to="7"/>
                                -->
      <!--  <ereg regexp="[0-9]{1,5}" search_in="hdr" header="To:" check_it="true" assign_to="6"/>
            	-->
                </action>

</recv>

<send>
<![CDATA[
SIP/2.0 100 Trying
[last_Via:]
[last_From:]
[last_To:]
[last_Call-ID:]
[last_CSeq:]
Supported: timer,100rel
Contact: <sip:[local_ip]:[local_port];transport=[transport]>
Content-Length: 0
]]>
</send>


<send>
<![CDATA[
SIP/2.0 200 OK
[last_Via:]
[last_From:]
[last_To:];tag=1
[last_Call-ID:]
[last_CSeq:]
Contact: <sip:[local_ip]:[local_port];transport=[transport]>
P-Asserted-Identity: <sip:81002001@rwtrunk.com>
Content-Type: application/sdp
Content-Length: [len]

v=0
o=user1 53655765 2353687637 IN IP[local_ip_type] [local_ip]
s=-
c=IN IP[media_ip_type] [media_ip]
t=0 0
m=audio [media_port] RTP/AVP 0
a=rtpmap:0 PCMU/8000
a=ptime:20
a=label:20
a=recvonly
m=audio [media_port+2] RTP/AVP 0
a=rtpmap:0 PCMU/8000
a=ptime:20
a=label:10
a=recvonly
]]>
</send>

<recv request="ACK" rtd="true" crlf="true">
<action>
  <ereg regexp="tag=.*"
            search_in="hdr"
                              header="From:"
                                                        check_it="true"
                                                                                          assign_to="1"/>

   <ereg regexp="tag=.*"
               search_in="hdr"
                                    header="To:"
                                                                  check_it="true"
                                                                                                         assign_to="2"/>

   <ereg regexp=".*"
                search_in="hdr"
                                       header="Call-ID:"
                                                                        check_it="true"
                                                                                                                   assign_to="3"/>
                                                                                                                                                               </action>
                                                                                                                                                               </recv>

<recv request="UPDATE" rtd="true" crlf="true"/>
<send>
<![CDATA[
SIP/2.0 200 OK
[last_Via:]
[last_From:]
[last_To:]
[last_Call-ID:]
[last_CSeq:]
Contact: <sip:[local_ip]:[local_port];transport=[transport]>
Content-Length: 0
]]>
</send>
